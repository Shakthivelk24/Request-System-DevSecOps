@Library('Shared')_

pipeline {
    agent {
        label 'shakthiAgent'
    }
    environment {
        // Application
        APP_NAME = 'request-system'
        APP_VERSION = "1.0.${BUILD_NUMBER}"

        // Docker Images
        DOCKER_USERNAME = 'shakthivelk24'

        FRONTEND_IMAGE = "${DOCKER_USERNAME}/requestsystem-frontend"
        BACKEND_IMAGE = "${DOCKER_USERNAME}/requestsystem-backend"

        IMAGE_TAG = "${BUILD_NUMBER}"

        // SonarQube
        SONAR_PROJECT_KEY = 'request-system'

        // Kubernetes
        K8S_NAMESPACE = 'request-system'

        // // Reports
        TRIVY_REPORT_DIR = 'reports/trivy'
        // ZAP_REPORT_DIR = 'reports/zap'

        // Application URL (after deployment)
        APP_URL = 'http://localhost'
    }
    options {
        // Add timestamps to all log lines for debugging
        timestamps()

        // Color ANSI codes in console output
        ansiColor('xterm')

        // Timeout the entire pipeline after 60 minutes
        // Prevents hung builds from consuming resources indefinitely
        timeout(time: 60, unit: 'MINUTES')

        // Keep only last 10 builds to save disk space
        buildDiscarder(logRotator(numToKeepStr: '10'))

        // Prevent multiple builds of the same branch running simultaneously
        disableConcurrentBuilds()
    }
    stages {
        // ====================================================
        // STAGE 1: CHECK TOOLS
        // ====================================================
        stage('Check Tools') {
            steps {
                cleanWs()
                customLog('Checking required tools...')
                check()
            }
        }
        // ====================================================
        // STAGE 2: CHECKOUT SOURCE CODE
        // ====================================================
        stage('🔄 Checkout') {
            steps {
                customLog('Checking out source code')

                checkout scm

                sh '''
                echo "========== Last 5 Commits =========="
                git log --oneline -5

                echo "========== Git Status =========="
                git status
            '''
            }
        }
        // ====================================================
        // STAGE 3: INSTALL DEPENDENCIES
        // ====================================================
        stage('📦 Install Dependencies') {
            parallel {
                stage('Frontend Dependencies') {
                    steps {
                        customLog('Installing frontend dependencies...')
                        npmInstall('client')
                    }
                }

                stage('Backend Dependencies') {
                    steps {
                        customLog('Installing backend dependencies...')
                        npmInstall('server')
                    }
                }
            }
        }
        // ====================================================
        // STAGE 4: RUN TESTS
        // Execute unit and integration tests
        // ====================================================
        stage('🧪 Run Tests') {
            parallel {
                stage('Frontend Tests') {
                    steps {
                        npmTest(
                         'client',
                         '../coverage/frontend',
                         'client/junit.xml'
                        )
                    }
                }

                stage('Backend Tests') {
                    steps {
                        npmTest(
                         'server',
                         '../coverage/backend',
                         'server/junit.xml'
                        )
                    }
                }
            }
        }
        // ====================================================
        // STAGE 5: STATIC CODE ANALYSIS
        // Run SonarQube analysis on the codebase
        // ====================================================
        stage('🔍 Static Code Analysis') {
            steps {
                customLog('Running SonarQube analysis...')
                sonarqubeScan(
                    scannerName: 'SonarScanner',
                    sonarServer: 'SonarQube',
                    projectKey: "$SONAR_PROJECT_KEY",
                    projectName: "$APP_NAME",
                    projectVersion: "$APP_VERSION",
                    sources: 'client/src,server',
                    exclusions: '**/node_modules/**,**/dist/**,**/coverage/**'
                )
                customLog('SonarQube analysis submitted')
            }
        }
        // ====================================================
        // STAGE 6: QUALITY GATE
        // Wait for SonarQube quality gate result
        // ====================================================
        stage('✅ Quality Gate') {
            steps {
                customLog('Waiting for SonarQube quality gate result...')
                qualityGate()
            }
        }
        // ====================================================
        // STAGE 7: BUILD APPLICATION
        // Compile React frontend for production
        // ====================================================
        stage('🏗️ Build Application') {
            parallel {
                stage('Build Frontend') {
                    steps {
                        customLog('Building frontend...')
                        frontendBuild('client')
                    }
                }

                stage('Validate Backend') {
                    steps {
                        customLog('Validating backend...')
                        backendValidate('server')
                    }
                }
            }
        }
        // ====================================================
        // STAGE 8: DOCKER LOGIN
        // Log in to Docker Hub to push images
        // ====================================================
        stage('🔑 Docker Login') {
            steps {
                customLog('Logging in to Docker Hub...')
                dockerLogin()
            }
        }
        // ====================================================
        // STAGE 9: BUILD DOCKER IMAGES
        // Build Docker images for frontend and backend
        // ====================================================
        stage('🐳 Build Docker Images') {
            parallel {
                stage('Build Frontend Image') {
                    steps {
                        customLog('Building frontend Docker image...')

                        dockerBuild(
                           FRONTEND_IMAGE,
                           'docker/frontend/Dockerfile',
                           '.',
                           IMAGE_TAG
                        )
                    }
                }

                stage('Build Backend Image') {
                    steps {
                        customLog('Building backend Docker image...')

                        dockerBuild(
                          BACKEND_IMAGE,
                          'docker/backend/Dockerfile',
                          '.',
                          IMAGE_TAG
                        )
                    }
                }
            }
        }
        // ====================================================
        // STAGE 10: TRIVY IMAGE SCAN
        // Scan Docker images for vulnerabilities
        // ====================================================
        stage('🛡️ Trivy Image Scan') {
            parallel {
                stage('Scan Frontend Image') {
                    steps {
                        trivyScan(
                          imageName: FRONTEND_IMAGE,
                          imageVersion: IMAGE_TAG,
                          reportDir: TRIVY_REPORT_DIR,
                          reportName: 'frontend'
                     )
                    }
                }

                stage('Scan Backend Image') {
                    steps {
                        trivyScan(
                          imageName: BACKEND_IMAGE,
                          imageVersion: IMAGE_TAG,
                          reportDir: TRIVY_REPORT_DIR,
                          reportName: 'backend'
                        )
                    }
                }
            }
        }

        // ====================================================
        // STAGE 11: TRIVY SECRET SCAN
        // Scan source code for hardcoded secrets
        // ====================================================
        stage('🔑 Trivy Secret Scan') {
            steps {
                trivySecretScan(
                  reportDir: TRIVY_REPORT_DIR
                )
            }
        }
        // ====================================================
        // STAGE 12: PUSH DOCKER IMAGES
        // Push Docker images to Docker Hub
        // ====================================================
        stage('📤 Push Docker Images') {
            parallel {
                stage('Push Frontend Image') {
                    steps {
                        customLog('Pushing frontend Docker image...')

                        dockerPush(
                          imageName: FRONTEND_IMAGE,
                          imageVersion: IMAGE_TAG
                        )
                    }
                }

                stage('Push Backend Image') {
                    steps {
                        customLog('Pushing backend Docker image...')

                        dockerPush(
                          imageName: BACKEND_IMAGE,
                          imageVersion: IMAGE_TAG
                        )
                    }
                }
            }
        }
    }
}
